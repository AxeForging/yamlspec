[10.851579, "o", "\r\n"]
[10.853001, "o", "apiVersion: apps/v1\r\nkind: Deployment\r\nmetadata:\r\n  name: web\r\n  namespace: production\r\nspec:\r\n  replicas: 3\r\n  selector:\r\n    matchLabels:\r\n      app: web\r\n  template:\r\n    metadata:\r\n      labels:\r\n        app: web\r\n    spec:\r\n      containers:\r\n        - name: web\r\n          image: nginx:1.25.3\r\n          resources:\r\n            limits:\r\n              cpu: \"500m\"\r\n              memory: \"256Mi\"\r\n"]

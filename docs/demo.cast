[0.017382, "o", "\u001b[H\u001b[J\u001b[3J"]
[0.519245, "o", "\u001b[2;36m# yamlspec — RSpec-like assertions for any YAML\u001b[0m\r\n"]
[2.021317, "o", "\u001b[2;36m# Define what 'good' looks like in spec.yaml:\u001b[0m\r\n"]
[2.923289, "o", "\u001b[1;32m$\u001b[0m c"]

[27.932694, "o", "\r\n  \u001b[31m✗\u001b[0m \u001b[1mProduction deployment\u001b[0m\r\n    Deployment\r\n      \u001b[36m[select: select(.kind == \"Deployment\")]\u001b[0m\r\n      \u001b[31m✗\u001b[0m have 3 replicas\r\n        \u001b[2m\u001b[31mexpected 'spec.replicas' to equal 3, got 1\u001b[0m\r\n      \u001b[32m✓\u001b[0m be in production namespace\r\n      \u001b[32m✓\u001b[0m use a pinned image tag\r\n      \u001b[32m✓\u001b[0m have CPU limits\r\n\r\n\r\n\u001b[31m\u001b[1mFailures:\u001b[0m\r\n\r\n  \u001b[31m1) Production deployment > Deployment > have 3 replicas\u001b[0m\r\n     \u001b[2mexpected 'spec.replicas' to equal 3, got 1\u001b[0m\r\n\r\n\r\n4 assertions, \u001b[32m3 passed\u001b[0m, \u001b[31m1 failed\u001b[0m\r\nFinished in 0.00s\r\n\r\n"]

[4.597326, "o", "\r\n"]
[4.59877, "o", "name: \"Production deployment\"\r\ntags: [\"production\", \"deployment\"]\r\n\r\ndescribe:\r\n  - name: \"Deployment\"\r\n    select: 'select(.kind == \"Deployment\")'\r\n    it:\r\n      - should: \"have 3 replicas\"\r\n        expect: spec.replicas\r\n        toEqual: 3\r\n\r\n      - should: \"be in production namespace\"\r\n        expect: metadata.namespace\r\n        toEqual: \"production\"\r\n\r\n      - should: \"use a pinned image tag\"\r\n        expect: spec.template.spec.containers[0].image\r\n        toNotEndWith: \":latest\"\r\n\r\n      - should: \"have CPU limits\"\r\n        expect: spec.template.spec.containers[0].resources.limits.cpu\r\n        toExist: true\r\n"]
[7.6026, "o", "\u001b[H\u001b[J\u001b[3J"]
[7.602851, "o", "\u001b[2;36m# And the manifest we want to validate:\u001b[0m\r\n"]
